#!/usr/bin/env python3
"""Dev launcher for the `zown` CLI without installing the package.

Adds the repo root to sys.path so `python bin/zown ...` (or a symlink on PATH)
works straight from a fresh checkout.
"""
import os
import sys

_ROOT = os.path.dirname(os.path.dirname(os.path.abspath(__file__)))
if _ROOT not in sys.path:
    sys.path.insert(0, _ROOT)

from zown.cli import main  # noqa: E402

if __name__ == "__main__":
    raise SystemExit(main())
